{
  "name": "@taskflow/backend",
  "version": "1.0.0",
  "description": "TaskFlow Backend API - Multi-tenant Project Management SaaS",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx ts-node-dev --respawn --transpile-only index.ts",
    "debug": "npx ts-node-dev --respawn --transpile-only scripts/index-debug.ts",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "migrate": "npx knex migrate:latest",
    "migrate:rollback": "npx knex migrate:rollback",
    "seed": "npx knex seed:run",
    "maintenance:fix-schema": "npx ts-node scripts/fix-schema.ts",
    "maintenance:check-usage": "npx ts-node scripts/check-usage.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1019.0",
    "@types/cors": "^2.8.19",
    "@types/morgan": "^1.9.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "type": "commonjs"
}
