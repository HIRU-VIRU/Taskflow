{
  "name": "@taskflow/backend",
  "version": "1.0.0",
  "description": "TaskFlow Backend API - Multi-tenant Project Management SaaS",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx ts-node-dev --respawn --transpile-only index.ts",
    "debug": "npx ts-node-dev --respawn --transpile-only index-debug.ts",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "migrate": "npx knex migrate:latest --knexfile ../scripts/knexfile.ts",
    "migrate:rollback": "npx knex migrate:rollback --knexfile ../scripts/knexfile.ts",
    "seed": "npx knex seed:run --knexfile ../scripts/knexfile.ts"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "type": "commonjs"
}