{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "Multi-tenant Project Management SaaS with Subscription & Feature Entitlement System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "debug": "ts-node-dev --respawn --transpile-only src/index-debug.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:preview": "cd frontend && npm run preview",
    "dev:all": "concurrently \"npm run dev\" \"npm run frontend:dev\"",
    "install:all": "npm install && npm run frontend:install",
    "build:all": "npm run build && npm run frontend:build"
  },
  "keywords": [
    "saas",
    "multi-tenant",
    "project-management",
    "subscription"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "concurrently": "^9.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HIRU-VIRU/Taskflow.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/HIRU-VIRU/Taskflow/issues"
  },
  "homepage": "https://github.com/HIRU-VIRU/Taskflow#readme"
}
