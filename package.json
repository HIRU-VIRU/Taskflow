{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "Multi-tenant Project Management SaaS with Subscription & Feature Entitlement System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only backend/index.ts",
    "debug": "ts-node-dev --respawn --transpile-only backend/index-debug.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "knex migrate:latest --knexfile scripts/knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile scripts/knexfile.ts",
    "seed": "knex seed:run --knexfile scripts/knexfile.ts",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:preview": "cd frontend && npm run preview",
    "install:all": "npm install && npm run frontend:install",
    "build:all": "npm run build && npm run frontend:build",
    "db:start": "docker run --name taskflow-db -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=taskflow -p 5432:5432 -d postgres:16-alpine",
    "db:stop": "docker stop taskflow-db && docker rm taskflow-db",
    "db:setup": "npm run migrate && npm run seed"
  },
  "keywords": [
    "saas",
    "multi-tenant",
    "project-management",
    "subscription"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HIRU-VIRU/Taskflow.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/HIRU-VIRU/Taskflow/issues"
  },
  "homepage": "https://github.com/HIRU-VIRU/Taskflow#readme"
}
